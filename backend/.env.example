# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL connection string
# Use Session Pooler URL from Supabase if direct connection fails (IPv6 issue)
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# JWT signing secret — generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7


MPESA_CONSUMER_KEY=your_consumer_key_from_dashboard
MPESA_CONSUMER_SECRET=your_consumer_secret_from_dashboard
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=callback_url
